{
	"name": "@ncukondo/yaml-form",
	"version": "0.3.1",
	"description": "Generate self-contained HTML forms from YAML definitions",
	"type": "module",
	"bin": {
		"yaml-form": "./dist/cli.js"
	},
	"scripts": {
		"test": "bun test",
		"typecheck": "bun x tsc --noEmit",
		"build:schema": "bun scripts/build-schema.ts",
		"lint": "bun x biome check .",
		"format": "bun x biome format --write .",
		"check": "bun run build:runtime && bun run build:embedded && bun run typecheck && bun run lint && bun test",
		"build:runtime": "bun scripts/build-runtime.ts",
		"build:embedded": "bun scripts/build-embedded.ts",
		"build:dist": "bun scripts/build-dist.ts",
		"prepack": "bun run build:dist"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.4",
		"@happy-dom/global-registrator": "^20.10.6",
		"@types/bun": "latest",
		"happy-dom": "^20.10.6",
		"typescript": "^5.8.0"
	},
	"dependencies": {
		"@ncukondo/dynamic-form-rules": "^0.0.7",
		"yaml": "^2.9.0",
		"zod": "^4.4.3"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ncukondo/yaml-form-cli.git"
	},
	"files": [
		"dist/cli.js",
		"schema"
	],
	"publishConfig": {
		"access": "public"
	}
}
